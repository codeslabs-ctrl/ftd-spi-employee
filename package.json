{
  "name": "ftd-spi-employee",
  "version": "1.0.0",
  "description": "SPI Employee API — Express + App Engine (FTD archetype), Nest SPI HTTP contracts preserved",
  "main": "dist/index.js",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "start": "node ./dist/index.js",
    "clean": "rimraf dist",
    "dev": "cross-env NODE_ENV=development ts-node-dev --respawn --transpile-only src/index.ts",
    "qa": "cross-env NODE_ENV=staging ts-node-dev --respawn --transpile-only src/index.ts",
    "prd": "cross-env NODE_ENV=production ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p .",
    "build-gcp": "tsc -p .",
    "deploy": "cross-env NODE_ENV=production npm run clean && npm run build-gcp && gcloud app deploy",
    "sync-env": "node sync-env-to-yaml.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@google-cloud/logging-winston": "^6.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.2.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "oracledb": "^6.8.0",
    "reflect-metadata": "^0.2.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.21",
    "@types/oracledb": "^6.6.1",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "rimraf": "^6.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
