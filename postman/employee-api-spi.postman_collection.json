{
  "info": {
    "name": "Employee API SPI",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "CRUD de empleados SPI multi-tenant.\n\nVariables: {{baseUrl}}, {{clientId}}, {{clientSecret}}, {{payloadKey}}.\nEl token se guarda automáticamente al ejecutar Auth > Get Token.\n\nCifrado de payload (P2C): el folder 'Encrypted (P2C)' usa la librería CryptoJS (integrada en Postman) para cifrar el body en 'RequestJson' y descifrar 'ResponseJson', igual que el front. La llave va en {{payloadKey}} (debe coincidir con PAYLOAD_ENCRYPTION_KEY del backend)."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "clientId", "value": "hr-integration" },
    { "key": "clientSecret", "value": "local-secret-2026" },
    { "key": "payloadKey", "value": "portal-shared-key-2026" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Get Token (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('expires_in is 12h', () => pm.expect(pm.response.json().expires_in).to.eql(43200));",
                  "pm.collectionVariables.set('token', pm.response.json().access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/token",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_id\": \"{{clientId}}\",\n  \"client_secret\": \"{{clientSecret}}\"\n}"
            }
          }
        },
        {
          "name": "Get Token wrong secret (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('status 401', () => pm.response.to.have.status(401));"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/token",
            "body": { "mode": "raw", "raw": "{\n  \"client_id\": \"{{clientId}}\",\n  \"client_secret\": \"wrong\"\n}" }
          }
        }
      ]
    },
