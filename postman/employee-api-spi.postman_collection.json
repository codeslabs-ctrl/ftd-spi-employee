    {
      "name": "Encrypted (P2C)",
      "description": "Cifrado de payload con CryptoJS.AES (librería crypto-js, integrada en Postman) igual que el front. Requiere {{payloadKey}} = PAYLOAD_ENCRYPTION_KEY del backend. El pre-request cifra el body en RequestJson; el test descifra ResponseJson.",
      "item": [
        {
          "name": "Create employee (encrypted 201)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const employee = {",
                  "  idNumber: '12345678', idType: 'V', nationality: 'VENEZOLANO',",
                  "  firstName: 'MARIA', middleName: 'ALEJANDRA', lastName: 'PEREZ', secondLastName: 'GOMEZ',",
                  "  birthDate: '1990-05-14', gender: 'F', maritalStatus: 'SOLTERA',",
                  "  city: 'CARACAS', mobile: '04141234567', email: 'maria.perez@mail.com'",
                  "};",
                  "const key = pm.collectionVariables.get('payloadKey');",
                  "// Igual que el front: CryptoJS.AES.encrypt(JSON.stringify(data), KEY).toString()",
                  "const cipher = CryptoJS.AES.encrypt(JSON.stringify(employee), key).toString();",
                  "pm.collectionVariables.set('encRequest', cipher);",
                  "console.log('RequestJson (cifrado):', cipher.slice(0, 24) + '...');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "const key = pm.collectionVariables.get('payloadKey');",
                  "const enc = pm.response.json().ResponseJson;",
                  "pm.test('respuesta viene cifrada (ResponseJson)', () => pm.expect(enc).to.be.a('string'));",
                  "const clear = JSON.parse(CryptoJS.AES.decrypt(enc, key).toString(CryptoJS.enc.Utf8));",
                  "console.log('ResponseJson (descifrado):', clear);",
                  "pm.test('idNumber correcto tras descifrar', () => pm.expect(clear.idNumber).to.eql('12345678'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Country-Code", "value": "VE" }
            ],
            "url": "{{baseUrl}}/api/v1/employees",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [{ "key": "RequestJson", "value": "{{encRequest}}" }]
            }
          }
        },
        {
          "name": "Search employee (encrypted 200)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const payload = { idNumber: '12345678' };",
                  "const key = pm.collectionVariables.get('payloadKey');",
                  "pm.collectionVariables.set('encRequest', CryptoJS.AES.encrypt(JSON.stringify(payload), key).toString());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const key = pm.collectionVariables.get('payloadKey');",
                  "const clear = JSON.parse(CryptoJS.AES.decrypt(pm.response.json().ResponseJson, key).toString(CryptoJS.enc.Utf8));",
                  "console.log('ResponseJson (descifrado):', clear);",
                  "pm.test('idNumber correcto', () => pm.expect(clear.idNumber).to.eql('12345678'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Country-Code", "value": "VE" }
            ],
            "url": "{{baseUrl}}/api/v1/employees/search",
            "body": { "mode": "urlencoded", "urlencoded": [{ "key": "RequestJson", "value": "{{encRequest}}" }] }
          }
