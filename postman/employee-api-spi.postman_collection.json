{
  "info": {
    "name": "Employee API SPI",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "CRUD de empleados SPI multi-tenant. Variables: {{baseUrl}}, {{clientId}}, {{clientSecret}}. El token se guarda automáticamente al ejecutar Auth > Get Token."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "clientId", "value": "hr-integration" },
    { "key": "clientSecret", "value": "" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Get Token (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('expires_in is 12h', () => pm.expect(pm.response.json().expires_in).to.eql(43200));",
                  "pm.collectionVariables.set('token', pm.response.json().access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/token",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_id\": \"{{clientId}}\",\n  \"client_secret\": \"{{clientSecret}}\"\n}"
            }
          }
        },
        {
          "name": "Get Token wrong secret (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('status 401', () => pm.response.to.have.status(401));"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/token",
            "body": { "mode": "raw", "raw": "{\n  \"client_id\": \"{{clientId}}\",\n  \"client_secret\": \"wrong\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Employees VE",
      "item": [
        {
          "name": "Create employee (201)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('status 201', () => pm.response.to.have.status(201));"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Country-Code", "value": "VE" }
            ],
            "url": "{{baseUrl}}/api/v1/employees",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idNumber\": \"12345678\",\n  \"nationality\": \"V\",\n  \"firstName\": \"MARIA\",\n  \"middleName\": \"ALEJANDRA\",\n  \"lastName\": \"PEREZ\",\n  \"secondLastName\": \"GOMEZ\",\n  \"birthDate\": \"1990-05-14\",\n  \"gender\": \"F\"\n}"
            }
          }
        },
        {
          "name": "Get employee by id (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('status 200', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Country-Code", "value": "VE" }
            ],
            "url": "{{baseUrl}}/api/v1/employees/12345678"
          }
        },
        {
          "name": "List employees (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('status 200', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Country-Code", "value": "VE" }
            ],
            "url": "{{baseUrl}}/api/v1/employees?page=1&size=20"
          }
        },
        {
          "name": "Update employee (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('status 200', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Country-Code", "value": "VE" }
            ],
            "url": "{{baseUrl}}/api/v1/employees/12345678",
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"MARIA ALEJANDRA\"\n}" }
          }
        },
        {
          "name": "Delete employee (204)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('status 204', () => pm.response.to.have.status(204));"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Country-Code", "value": "VE" }
            ],
            "url": "{{baseUrl}}/api/v1/employees/12345678"
          }
        }
      ]
    },
    {
      "name": "Negative cases",
      "item": [
        {
          "name": "No token (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('status 401', () => pm.response.to.have.status(401));"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Country-Code", "value": "VE" }],
            "url": "{{baseUrl}}/api/v1/employees/12345678"
          }
        },
        {
          "name": "Missing X-Country-Code (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('status 400', () => pm.response.to.have.status(400));"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/employees/12345678"
          }
        },
        {
          "name": "Country not enabled AR (422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('status 422', () => pm.response.to.have.status(422));"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Country-Code", "value": "AR" }
            ],
            "url": "{{baseUrl}}/api/v1/employees/12345678"
          }
        },
        {
          "name": "Invalid body (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 400', () => pm.response.to.have.status(400));",
                  "pm.test('per-field errors', () => pm.expect(pm.response.json().errors.length).to.be.above(0));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Country-Code", "value": "VE" }
            ],
            "url": "{{baseUrl}}/api/v1/employees",
            "body": { "mode": "raw", "raw": "{\n  \"idNumber\": \"\"\n}" }
          }
        },
        {
          "name": "Duplicate create (409/422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 409 or 422', () => pm.expect([409, 422]).to.include(pm.response.code));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Country-Code", "value": "VE" }
            ],
            "url": "{{baseUrl}}/api/v1/employees",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idNumber\": \"12345678\",\n  \"nationality\": \"V\",\n  \"firstName\": \"MARIA\",\n  \"lastName\": \"PEREZ\",\n  \"birthDate\": \"1990-05-14\",\n  \"gender\": \"F\"\n}"
            }
          }
        }
      ]
    }
  ]
}
