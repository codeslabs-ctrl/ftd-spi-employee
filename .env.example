# Server
PORT=8080

# Logging: info|debug|warn|error|silent. Production → JSON a stdout (Cloud Logging).
# Local (NODE_ENV≠production) → pino-pretty. Nunca escribe archivos .log en Cloud Run.
# LOG_LEVEL=info

# Timeout global del handler HTTP (ms). 408 Request Timeout si se supera.
REQUEST_TIMEOUT_MS=30000

# Oracle pool / call timeouts (buenas prácticas del arquetipo FTD).
# poolTimeout: segundos idle antes de cerrar conexión del pool.
# queueTimeout / callTimeout: milisegundos.
ORACLE_POOL_TIMEOUT=300
ORACLE_QUEUE_TIMEOUT=60000
ORACLE_CALL_TIMEOUT=30000

# Dev/demo only: usa un repositorio en memoria en vez de Oracle (para probar el
# contrato HTTP completo sin BD). NUNCA activar en producción.
# FAKE_DB=true

# JWT (en Cloud Run vienen de Secret Manager; local: llaves de desarrollo en base64)
JWT_PRIVATE_KEY_BASE64=
JWT_PUBLIC_KEY_BASE64=
JWT_TTL_SECONDS=43200
JWT_ISSUER=ftd-spi-employee

# Clientes del API (JSON). "countries" es la lista de países que el cliente puede usar;
# debe incluir cada país que consultará (si no, el guard responde 403). Ej. multi-país:
# [{"clientId":"hr-integration","secretHash":"sha256hex","countries":["VE","CO"]}]
API_CLIENTS_JSON=[]

# PKG y códigos de PKG_GLOBAL_CONSTANTS (varían por entorno/esquema).
# QA usa el esquema people_one y los códigos FTD-200 / FTD-201.
# Defaults sin prefijo de esquema (se resuelven en people_one):
EMPLOYEE_PKG=pkg_management_employee
PKG_SUCCESS_CODE=FTD-200
PKG_NORECORDS_CODE=FTD-201

# Un PKG por dominio (mismo esquema que Employee). Un paquete por recurso:
POSITION_PKG=pkg_management_position
COMPANY_PKG=pkg_management_company
MARITAL_STATUS_PKG=pkg_management_marital_status
JOB_POST_PKG=pkg_management_job_post
ORG_UNIT_PKG=pkg_management_org_unit

# Cifrado de payload front<->back (CryptoJS.AES, passphrase compartida con el portal).
# Vacío = deshabilitado (el body viaja como JSON normal, protegido por TLS).
PAYLOAD_ENCRYPTION_KEY=

# CORS: orígenes del navegador permitidos, separados por coma. Vacío = CORS deshabilitado.
CORS_ORIGINS=https://mi-portal.farmatodo.com

# Multi-tenant: un bloque DB_<CC>_* por país. El servicio crea un pool Oracle por
# cada país con configuración completa (connect string + user + password). El header
# X-Country-Code (ISO 3166-1 alfa-2) enruta cada request a su BD. Habilitar un país
# nuevo = agregar su bloque aquí + incluir el código en API_CLIENTS_JSON.countries.
# NO requiere cambios de código.

# Venezuela (VE) — QA: dlved347:1521/NOMQAVE
DB_VE_CONNECT_STRING=host:1521/NOMQAVE
DB_VE_USER=people_one
DB_VE_PASSWORD=
DB_VE_POOL_MIN=1
DB_VE_POOL_MAX=3

# Colombia (CO) — QA: dlcod321.farmatodo.com:1521/NOMQACO
DB_CO_CONNECT_STRING=host:1521/NOMQACO
DB_CO_USER=people_one
DB_CO_PASSWORD=
DB_CO_POOL_MIN=1
DB_CO_POOL_MAX=3

# Argentina (AR) — pendiente: descomentar y completar cuando exista la BD
# DB_AR_CONNECT_STRING=host:1521/NOMQAAR
# DB_AR_USER=people_one
# DB_AR_PASSWORD=
# DB_AR_POOL_MIN=1
# DB_AR_POOL_MAX=3
