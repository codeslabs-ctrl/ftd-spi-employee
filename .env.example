# Server
PORT=8080

# Dev/demo only: usa un repositorio en memoria en vez de Oracle (para probar el
# contrato HTTP completo sin BD). NUNCA activar en producción.
# FAKE_DB=true

# JWT (en Cloud Run vienen de Secret Manager; local: llaves de desarrollo en base64)
JWT_PRIVATE_KEY_BASE64=
JWT_PUBLIC_KEY_BASE64=
JWT_TTL_SECONDS=43200
JWT_ISSUER=employee-api-spi

# Clientes del API (JSON: [{"clientId":"...","secretHash":"sha256hex","countries":["VE"]}])
API_CLIENTS_JSON=[]

# Cifrado de payload front<->back (CryptoJS.AES, passphrase compartida con el portal).
# Vacío = deshabilitado (el body viaja como JSON normal, protegido por TLS).
PAYLOAD_ENCRYPTION_KEY=

# CORS: orígenes del navegador permitidos, separados por coma. Vacío = CORS deshabilitado.
CORS_ORIGINS=https://mi-portal.farmatodo.com

# Venezuela (único país habilitado en fase 1)
DB_VE_CONNECT_STRING=host:1521/SPI
DB_VE_USER=corsox
DB_VE_PASSWORD=
DB_VE_POOL_MIN=1
DB_VE_POOL_MAX=5

# Para habilitar AR/CO: agregar DB_AR_* / DB_CO_* (sin cambios de código)
